NODE_ENV=development
PORT=3002
FRONTEND_URL=http://localhost:3000
# If you see MySQL 1045 "Access denied", the MySQL user/password or host is wrong.
# Use: mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE — URL-encode special characters in PASSWORD.
DATABASE_URL=mysql://root:@127.0.0.1:3306/ideaxrbb_idealweddings
# Set true only on an empty DB; false avoids ER_TABLE_EXISTS_ERROR when `user` already exists.
TYPEORM_SYNCHRONIZE=false
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Email provider (optional in dev, required if EMAIL_REQUIRED=true).
SENDGRID_API_KEY=
FROM_EMAIL=noreply@example.com
EMAIL_REQUIRED=false
