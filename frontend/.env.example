NODE_ENV=production
PORT=3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000
# Auth: origin only (no /api/v1). Must be the Nest auth-service, not the Next frontend URL.
# Production: e.g. https://api-auth.idealweddings.space — and that host must actually run auth-service on 3002 (or proxied).
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:3002
# Server-side proxies (login, refresh, etc.) prefer this over NEXT_PUBLIC_* when set.
AUTH_SERVICE_URL=http://localhost:3002
# Prisma; must match a MySQL user that can connect. Error 1045 in tools = fix credentials here and in auth-service/.env.
DATABASE_URL=mysql://root:@127.0.0.1:3306/ideaxrbb_idealweddings
JWT_SECRET=replace_with_strong_secret
